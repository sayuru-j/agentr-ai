{
  "name": "@agentr/worker",
  "version": "0.1.0",
  "description": "AgentRelay local worker — outbound WSS + Cursor CLI execution",
  "type": "module",
  "bin": {
    "agent-relay-worker": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agentr/shared": "*",
    "jimp": "^1.6.1",
    "screenshot-desktop": "^1.15.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/screenshot-desktop": "^1.12.3",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "license": "MIT"
}
