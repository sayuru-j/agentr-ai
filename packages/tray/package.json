{
  "name": "@agentr/tray",
  "version": "0.1.0",
  "description": "AgentRelay Windows system tray app",
  "author": "AgentR",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "start": "npm run build && node scripts/use-workspace-deps.mjs && electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare-pack": "node scripts/prepare-pack.mjs",
    "pack:win": "npm run build && npm run prepare-pack && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --config electron-builder.yml",
    "dist": "npm run pack:win"
  },
  "dependencies": {
    "@agentr/worker": "*",
    "jimp": "^1.6.1",
    "screenshot-desktop": "^1.15.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "cross-env": "^7.0.3",
    "electron": "33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3"
  },
  "license": "MIT"
}
