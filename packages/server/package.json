{
  "name": "@agentr/server",
  "version": "0.1.0",
  "description": "AgentRelay VM relay — Teams bot + WebSocket router",
  "type": "module",
  "bin": {
    "agent-relay-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agentr/shared": "*",
    "botbuilder": "^4.23.1",
    "botframework-connector": "^4.23.1",
